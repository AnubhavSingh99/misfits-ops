import React, { useState, useEffect } from 'react'
import { TrendingUp, Calendar, Activity, MapPin, Users, ArrowUp, ArrowDown, Minus, Zap, Target, Trophy, Sparkles, BarChart3 } from 'lucide-react'
import { UniversalFilter } from '../components/UniversalFilter'

interface FilterState {
  viewAs: string;
  pocId?: string;
  activity: string;
  city: string;
  area: string;
  health: string;
  stage: string;
  search: string;
}

interface Period {
  start: string;
  end: string;
  revenue: number;
}

interface GrowthData {
  period1: Period;
  period2: Period;
  totalGrowth: {
    absoluteGrowth: number;
    percentGrowth: number;
  };
  attribution: {
    existingClubs: {
      revenue: number;
      percentage: number;
    };
    newClubs: {
      revenue: number;
      percentage: number;
    };
  };
  clubCounts: {
    total: number;
    existing: number;
    new: number;
  };
  clubDetails: Array<{
    meetup_id: number;
    name: string;
    activity: string;
    city: string;
    period1_revenue: number;
    period2_revenue: number;
    growth: number;
    growth_percentage: number;
    type: 'existing' | 'new';
  }>;
}

export function RevenueGrowth() {
  const [filters, setFilters] = useState<FilterState>({
    viewAs: 'All Data',
    activity: 'All',
    city: 'All',
    area: 'All',
    health: 'All',
    stage: 'All',
    search: ''
  });

  // Time period state
  const [period1, setPeriod1] = useState({
    start: '2024-09-01',
    end: '2024-09-30'
  });

  const [period2, setPeriod2] = useState({
    start: '2024-12-01',
    end: '2024-12-31'
  });

  const [growthData, setGrowthData] = useState<GrowthData | null>(null);
  const [loading, setLoading] = useState(false);

  // Fetch growth analysis data
  const fetchGrowthData = async () => {
    setLoading(true);
    try {
      const params = new URLSearchParams({
        period1_start: period1.start,
        period1_end: period1.end,
        period2_start: period2.start,
        period2_end: period2.end,
      });

      if (filters.activity !== 'All') params.append('activity', filters.activity);
      if (filters.city !== 'All') params.append('city', filters.city);
      if (filters.pocId) params.append('poc_id', filters.pocId);

      const response = await fetch(`/api/revenue/growth?${params}`);
      const data = await response.json();

      if (data.success) {
        setGrowthData(data);
      }
    } catch (error) {
      console.error('Failed to fetch growth data:', error);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchGrowthData();
  }, [filters, period1, period2]);

  const handleFilterChange = (newFilters: FilterState) => {
    setFilters(newFilters);
  };

  const formatRevenue = (amount: number) => {
    if (amount >= 100000) return `₹${(amount / 100000).toFixed(1)}L`;
    if (amount >= 1000) return `₹${(amount / 1000).toFixed(0)}K`;
    return `₹${amount.toFixed(0)}`;
  };

  const getGrowthIcon = (growth: number) => {
    if (growth > 0) return <ArrowUp className="h-4 w-4 text-green-500" />;
    if (growth < 0) return <ArrowDown className="h-4 w-4 text-red-500" />;
    return <Minus className="h-4 w-4 text-gray-500" />;
  };

  const getGrowthColor = (growth: number) => {
    if (growth > 0) return 'text-green-600';
    if (growth < 0) return 'text-red-600';
    return 'text-gray-600';
  };

  return (
    <div className="min-h-screen bg-gray-50">
      {/* Universal Filter */}
      <UniversalFilter
        onFilterChange={handleFilterChange}
        currentView={filters.viewAs}
      />

      <div className="p-6 max-w-7xl mx-auto space-y-6">
        {/* Header */}
        <div className="relative bg-gradient-to-br from-purple-600 via-blue-600 to-indigo-700 rounded-2xl p-8 text-white shadow-2xl overflow-hidden">
          {/* Background decoration */}
          <div className="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-16 translate-x-16"></div>
          <div className="absolute bottom-0 left-0 w-24 h-24 bg-white/5 rounded-full translate-y-12 -translate-x-12"></div>

          <div className="relative z-10">
            <div className="flex items-center justify-between mb-6">
              <div className="flex items-center gap-4">
                <div className="p-3 bg-white/20 rounded-xl backdrop-blur-sm">
                  <TrendingUp className="h-8 w-8" />
                </div>
                <div>
                  <h1 className="text-3xl font-bold mb-1">Revenue Growth Analysis</h1>
                  <p className="text-purple-100 text-lg">
                    Compare revenue performance across time periods with growth attribution
                  </p>
                </div>
              </div>
              <div className="flex items-center gap-2 px-3 py-1 bg-white/20 rounded-full backdrop-blur-sm">
                <div className="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                <span className="text-sm font-medium">Live Data</span>
              </div>
            </div>
          </div>
        </div>

        {/* Time Period Selector */}
        <div className="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
          <div className="flex items-center gap-3 mb-6">
            <div className="p-2 bg-blue-100 rounded-lg">
              <Calendar className="h-5 w-5 text-blue-600" />
            </div>
            <h2 className="text-xl font-bold text-gray-900">Time Period Comparison</h2>
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div className="space-y-4">
              <div className="flex items-center gap-2">
                <div className="w-3 h-3 bg-blue-500 rounded-full"></div>
                <label className="text-lg font-semibold text-gray-800">
                  Period 1 (Baseline)
                </label>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div className="relative">
                  <input
                    type="date"
                    value={period1.start}
                    onChange={(e) => setPeriod1({...period1, start: e.target.value})}
                    className="w-full border-2 border-gray-200 rounded-xl p-4 text-sm font-medium focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all duration-200"
                  />
                  <span className="absolute -top-2 left-3 px-2 bg-white text-xs font-medium text-gray-500">Start Date</span>
                </div>
                <div className="relative">
                  <input
                    type="date"
                    value={period1.end}
                    onChange={(e) => setPeriod1({...period1, end: e.target.value})}
                    className="w-full border-2 border-gray-200 rounded-xl p-4 text-sm font-medium focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all duration-200"
                  />
                  <span className="absolute -top-2 left-3 px-2 bg-white text-xs font-medium text-gray-500">End Date</span>
                </div>
              </div>
            </div>

            <div className="space-y-4">
              <div className="flex items-center gap-2">
                <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                <label className="text-lg font-semibold text-gray-800">
                  Period 2 (Comparison)
                </label>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div className="relative">
                  <input
                    type="date"
                    value={period2.start}
                    onChange={(e) => setPeriod2({...period2, start: e.target.value})}
                    className="w-full border-2 border-gray-200 rounded-xl p-4 text-sm font-medium focus:border-green-500 focus:ring-4 focus:ring-green-100 transition-all duration-200"
                  />
                  <span className="absolute -top-2 left-3 px-2 bg-white text-xs font-medium text-gray-500">Start Date</span>
                </div>
                <div className="relative">
                  <input
                    type="date"
                    value={period2.end}
                    onChange={(e) => setPeriod2({...period2, end: e.target.value})}
                    className="w-full border-2 border-gray-200 rounded-xl p-4 text-sm font-medium focus:border-green-500 focus:ring-4 focus:ring-green-100 transition-all duration-200"
                  />
                  <span className="absolute -top-2 left-3 px-2 bg-white text-xs font-medium text-gray-500">End Date</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        {loading ? (
          <div className="flex justify-center items-center py-16">
            <div className="relative">
              <div className="animate-spin rounded-full h-12 w-12 border-4 border-purple-200"></div>
              <div className="animate-spin rounded-full h-12 w-12 border-4 border-purple-600 border-t-transparent absolute top-0 left-0"></div>
              <div className="absolute inset-0 flex items-center justify-center">
                <BarChart3 className="h-5 w-5 text-purple-600 animate-pulse" />
              </div>
            </div>
          </div>
        ) : growthData ? (
          <>
            {/* Overall Growth Metrics */}
            <div className="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
              <div className="flex items-center gap-3 mb-8">
                <div className="p-2 bg-gradient-to-br from-purple-500 to-blue-500 rounded-lg">
                  <BarChart3 className="h-5 w-5 text-white" />
                </div>
                <h3 className="text-xl font-bold text-gray-900">Overall Growth Metrics</h3>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div className="relative group">
                  <div className="absolute inset-0 bg-gradient-to-r from-blue-400 to-blue-600 rounded-2xl opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
                  <div className="relative bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-6 border border-blue-200 hover:shadow-lg transition-all duration-300">
                    <div className="flex items-center justify-between mb-4">
                      <span className="text-sm font-semibold text-blue-700 uppercase tracking-wider">Period 1 (Baseline)</span>
                      <div className="p-2 bg-blue-500 rounded-lg">
                        <Calendar className="h-4 w-4 text-white" />
                      </div>
                    </div>
                    <div className="text-3xl font-bold text-blue-900 mb-2">
                      {formatRevenue(growthData.period1.revenue)}
                    </div>
                    <div className="text-sm text-blue-600 font-medium">
                      {period1.start} → {period1.end}
                    </div>
                  </div>
                </div>

                <div className="relative group">
                  <div className="absolute inset-0 bg-gradient-to-r from-green-400 to-green-600 rounded-2xl opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
                  <div className="relative bg-gradient-to-br from-green-50 to-green-100 rounded-2xl p-6 border border-green-200 hover:shadow-lg transition-all duration-300">
                    <div className="flex items-center justify-between mb-4">
                      <span className="text-sm font-semibold text-green-700 uppercase tracking-wider">Period 2 (Current)</span>
                      <div className="p-2 bg-green-500 rounded-lg">
                        <Target className="h-4 w-4 text-white" />
                      </div>
                    </div>
                    <div className="text-3xl font-bold text-green-900 mb-2">
                      {formatRevenue(growthData.period2.revenue)}
                    </div>
                    <div className="text-sm text-green-600 font-medium">
                      {period2.start} → {period2.end}
                    </div>
                  </div>
                </div>

                <div className="relative group">
                  <div className="absolute inset-0 bg-gradient-to-r from-purple-400 to-purple-600 rounded-2xl opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
                  <div className="relative bg-gradient-to-br from-purple-50 to-purple-100 rounded-2xl p-6 border border-purple-200 hover:shadow-lg transition-all duration-300">
                    <div className="flex items-center justify-between mb-4">
                      <span className="text-sm font-semibold text-purple-700 uppercase tracking-wider">Net Growth</span>
                      <div className="flex items-center gap-1">
                        {getGrowthIcon(growthData.totalGrowth.absoluteGrowth)}
                        <Trophy className="h-4 w-4 text-purple-500" />
                      </div>
                    </div>
                    <div className={`text-3xl font-bold mb-2 ${getGrowthColor(growthData.totalGrowth.absoluteGrowth)}`}>
                      {formatRevenue(growthData.totalGrowth.absoluteGrowth)}
                    </div>
                    <div className="flex items-center gap-2">
                      <span className="text-sm text-purple-600 font-medium">
                        {growthData.totalGrowth.percentGrowth.toFixed(1)}% change
                      </span>
                      <Sparkles className="h-3 w-3 text-purple-500" />
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Growth Attribution */}
            <div className="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
              <div className="flex items-center gap-3 mb-8">
                <div className="p-2 bg-gradient-to-br from-green-500 to-blue-500 rounded-lg">
                  <Zap className="h-5 w-5 text-white" />
                </div>
                <h3 className="text-xl font-bold text-gray-900">Growth Attribution</h3>
                <div className="ml-auto px-3 py-1 bg-gradient-to-r from-green-100 to-blue-100 rounded-full text-xs font-semibold text-gray-700">
                  Sources of Growth
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div className="relative group">
                  <div className="absolute inset-0 bg-gradient-to-r from-green-400 to-green-600 rounded-2xl opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                  <div className="relative bg-gradient-to-br from-green-50 to-emerald-50 border-2 border-green-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300">
                    <div className="flex items-center gap-3 mb-4">
                      <div className="p-3 bg-gradient-to-br from-green-500 to-emerald-500 rounded-xl">
                        <Users className="h-6 w-6 text-white" />
                      </div>
                      <span className="text-lg font-bold text-green-800">Existing Clubs</span>
                    </div>
                    <div className="space-y-3">
                      <div className="text-3xl font-black text-green-900">
                        {formatRevenue(growthData.attribution.existingClubs.revenue)}
                      </div>
                      <div className="flex items-center gap-2">
                        <div className="flex items-center gap-1 px-3 py-1 bg-green-200 rounded-full">
                          <div className="w-2 h-2 bg-green-600 rounded-full"></div>
                          <span className="text-sm font-bold text-green-800">
                            {growthData.attribution.existingClubs.percentage}% of growth
                          </span>
                        </div>
                      </div>
                      <div className="text-sm text-green-700 font-medium bg-green-100 rounded-lg p-3">
                        📈 {growthData.clubCounts.existing} clubs expanded operations
                      </div>
                    </div>
                  </div>
                </div>

                <div className="relative group">
                  <div className="absolute inset-0 bg-gradient-to-r from-blue-400 to-indigo-600 rounded-2xl opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
                  <div className="relative bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300">
                    <div className="flex items-center gap-3 mb-4">
                      <div className="p-3 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-xl">
                        <Activity className="h-6 w-6 text-white" />
                      </div>
                      <span className="text-lg font-bold text-blue-800">New Clubs</span>
                    </div>
                    <div className="space-y-3">
                      <div className="text-3xl font-black text-blue-900">
                        {formatRevenue(growthData.attribution.newClubs.revenue)}
                      </div>
                      <div className="flex items-center gap-2">
                        <div className="flex items-center gap-1 px-3 py-1 bg-blue-200 rounded-full">
                          <div className="w-2 h-2 bg-blue-600 rounded-full"></div>
                          <span className="text-sm font-bold text-blue-800">
                            {growthData.attribution.newClubs.percentage}% of growth
                          </span>
                        </div>
                      </div>
                      <div className="text-sm text-blue-700 font-medium bg-blue-100 rounded-lg p-3">
                        🚀 {growthData.clubCounts.new} new clubs launched
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {/* Progress Bar Visualization */}
              <div className="mt-8">
                <div className="flex items-center justify-between mb-3">
                  <span className="text-sm font-semibold text-gray-700">Growth Composition</span>
                  <span className="text-sm text-gray-500">100% Total Growth</span>
                </div>
                <div className="h-4 bg-gray-200 rounded-full overflow-hidden">
                  <div className="h-full flex">
                    <div
                      className="bg-gradient-to-r from-green-500 to-emerald-500 transition-all duration-1000 ease-out"
                      style={{ width: `${growthData.attribution.existingClubs.percentage}%` }}
                    ></div>
                    <div
                      className="bg-gradient-to-r from-blue-500 to-indigo-500 transition-all duration-1000 ease-out"
                      style={{ width: `${growthData.attribution.newClubs.percentage}%` }}
                    ></div>
                  </div>
                </div>
                <div className="flex justify-between mt-2 text-xs font-medium">
                  <span className="text-green-600">Existing: {growthData.attribution.existingClubs.percentage}%</span>
                  <span className="text-blue-600">New: {growthData.attribution.newClubs.percentage}%</span>
                </div>
              </div>
            </div>

            {/* Club-wise Breakdown */}
            {growthData.clubDetails && growthData.clubDetails.length > 0 && (
              <div className="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
                <div className="flex items-center justify-between mb-8">
                  <div className="flex items-center gap-3">
                    <div className="p-2 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-lg">
                      <BarChart3 className="h-5 w-5 text-white" />
                    </div>
                    <h3 className="text-xl font-bold text-gray-900">Club-wise Growth Breakdown</h3>
                  </div>
                  <div className="flex items-center gap-2 px-4 py-2 bg-gray-50 rounded-xl">
                    <div className="w-2 h-2 bg-indigo-500 rounded-full"></div>
                    <span className="text-sm font-medium text-gray-700">{growthData.clubDetails.length} Clubs</span>
                  </div>
                </div>

                <div className="overflow-x-auto">
                  <table className="min-w-full">
                    <thead>
                      <tr className="bg-gradient-to-r from-gray-50 to-gray-100 rounded-xl">
                        <th className="text-left py-4 px-6 font-bold text-gray-800 rounded-l-xl">Club Name</th>
                        <th className="text-left py-4 px-6 font-bold text-gray-800">Activity</th>
                        <th className="text-left py-4 px-6 font-bold text-gray-800">City</th>
                        <th className="text-right py-4 px-6 font-bold text-gray-800">Period 1</th>
                        <th className="text-right py-4 px-6 font-bold text-gray-800">Period 2</th>
                        <th className="text-right py-4 px-6 font-bold text-gray-800">Growth</th>
                        <th className="text-right py-4 px-6 font-bold text-gray-800">% Change</th>
                        <th className="text-center py-4 px-6 font-bold text-gray-800 rounded-r-xl">Type</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-gray-100">
                      {growthData.clubDetails.map((club, index) => (
                        <tr key={club.meetup_id} className="hover:bg-gradient-to-r hover:from-blue-25 hover:to-purple-25 transition-all duration-200 group">
                          <td className="py-4 px-6">
                            <div className="font-semibold text-gray-900 group-hover:text-indigo-700 transition-colors">
                              {club.name}
                            </div>
                          </td>
                          <td className="py-4 px-6">
                            <div className="flex items-center gap-2">
                              <div className="p-1 bg-blue-100 rounded-md">
                                <Activity className="h-3 w-3 text-blue-600" />
                              </div>
                              <span className="text-sm font-medium text-gray-700">{club.activity}</span>
                            </div>
                          </td>
                          <td className="py-4 px-6">
                            <div className="flex items-center gap-2">
                              <div className="p-1 bg-green-100 rounded-md">
                                <MapPin className="h-3 w-3 text-green-600" />
                              </div>
                              <span className="text-sm font-medium text-gray-700">{club.city}</span>
                            </div>
                          </td>
                          <td className="py-4 px-6 text-right">
                            <span className="font-semibold text-gray-800">
                              {formatRevenue(club.period1_revenue)}
                            </span>
                          </td>
                          <td className="py-4 px-6 text-right">
                            <span className="font-semibold text-gray-800">
                              {formatRevenue(club.period2_revenue)}
                            </span>
                          </td>
                          <td className={`py-4 px-6 text-right font-bold`}>
                            <div className={`flex items-center justify-end gap-2 px-3 py-1 rounded-lg ${
                              club.growth > 0
                                ? 'bg-green-100 text-green-800'
                                : club.growth < 0
                                  ? 'bg-red-100 text-red-800'
                                  : 'bg-gray-100 text-gray-800'
                            }`}>
                              {getGrowthIcon(club.growth)}
                              <span>{formatRevenue(Math.abs(club.growth))}</span>
                            </div>
                          </td>
                          <td className={`py-4 px-6 text-right font-bold`}>
                            <span className={`px-2 py-1 rounded-md text-sm ${
                              club.growth > 0
                                ? 'bg-green-50 text-green-700'
                                : club.growth < 0
                                  ? 'bg-red-50 text-red-700'
                                  : 'bg-gray-50 text-gray-700'
                            }`}>
                              {club.growth_percentage ? `${club.growth_percentage.toFixed(1)}%` : '-'}
                            </span>
                          </td>
                          <td className="py-4 px-6 text-center">
                            <span className={`inline-flex items-center gap-1 px-3 py-1 text-xs font-bold rounded-full border-2 ${
                              club.type === 'new'
                                ? 'bg-blue-50 text-blue-700 border-blue-200'
                                : 'bg-emerald-50 text-emerald-700 border-emerald-200'
                            }`}>
                              {club.type === 'new' ? (
                                <>
                                  <Sparkles className="h-3 w-3" />
                                  New
                                </>
                              ) : (
                                <>
                                  <TrendingUp className="h-3 w-3" />
                                  Expanded
                                </>
                              )}
                            </span>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {/* Insights & Recommendations */}
            <div className="bg-gradient-to-br from-amber-50 to-orange-50 border-2 border-amber-200 rounded-2xl p-8 shadow-lg">
              <div className="flex items-center gap-3 mb-6">
                <div className="p-3 bg-gradient-to-br from-amber-400 to-orange-500 rounded-xl">
                  <Zap className="h-6 w-6 text-white" />
                </div>
                <h3 className="text-xl font-bold text-amber-800">AI-Powered Insights & Recommendations</h3>
                <div className="ml-auto px-3 py-1 bg-amber-200 rounded-full text-xs font-bold text-amber-800">
                  Smart Analysis
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {growthData.attribution.newClubs.percentage > 50 && (
                  <div className="bg-white rounded-xl p-5 border border-blue-200 shadow-md hover:shadow-lg transition-shadow">
                    <div className="flex items-center gap-3 mb-3">
                      <div className="p-2 bg-blue-500 rounded-lg">
                        <Sparkles className="h-4 w-4 text-white" />
                      </div>
                      <span className="font-bold text-blue-800">New Club Strategy</span>
                    </div>
                    <p className="text-sm text-blue-700 leading-relaxed">
                      🚀 New clubs are driving <span className="font-bold">{growthData.attribution.newClubs.percentage}%</span> of growth.
                      <br /><br />
                      <span className="font-semibold">Action:</span> Focus on scaling successful formats and replicating launch strategies.
                    </p>
                  </div>
                )}

                {growthData.attribution.existingClubs.percentage > 60 && (
                  <div className="bg-white rounded-xl p-5 border border-green-200 shadow-md hover:shadow-lg transition-shadow">
                    <div className="flex items-center gap-3 mb-3">
                      <div className="p-2 bg-green-500 rounded-lg">
                        <TrendingUp className="h-4 w-4 text-white" />
                      </div>
                      <span className="font-bold text-green-800">Expansion Success</span>
                    </div>
                    <p className="text-sm text-green-700 leading-relaxed">
                      📈 Existing clubs showing strong expansion (<span className="font-bold">{growthData.attribution.existingClubs.percentage}%</span> of growth).
                      <br /><br />
                      <span className="font-semibold">Action:</span> Analyze and replicate high-performing expansion strategies.
                    </p>
                  </div>
                )}

                {growthData.clubDetails.some(club => club.growth < 0) && (
                  <div className="bg-white rounded-xl p-5 border border-red-200 shadow-md hover:shadow-lg transition-shadow">
                    <div className="flex items-center gap-3 mb-3">
                      <div className="p-2 bg-red-500 rounded-lg">
                        <Target className="h-4 w-4 text-white" />
                      </div>
                      <span className="font-bold text-red-800">Attention Needed</span>
                    </div>
                    <p className="text-sm text-red-700 leading-relaxed">
                      ⚠️ Some clubs showing decline detected.
                      <br /><br />
                      <span className="font-semibold">Action:</span> Immediate intervention required for underperforming clubs.
                    </p>
                  </div>
                )}

                {/* Always show best performer insight */}
                <div className="bg-white rounded-xl p-5 border border-purple-200 shadow-md hover:shadow-lg transition-shadow">
                  <div className="flex items-center gap-3 mb-3">
                    <div className="p-2 bg-purple-500 rounded-lg">
                      <Trophy className="h-4 w-4 text-white" />
                    </div>
                    <span className="font-bold text-purple-800">Top Performer</span>
                  </div>
                  <p className="text-sm text-purple-700 leading-relaxed">
                    🏆 Analyze your best-performing club's strategy.
                    <br /><br />
                    <span className="font-semibold">Action:</span> Document and replicate successful approaches across other clubs.
                  </p>
                </div>

                {/* Revenue velocity insight */}
                <div className="bg-white rounded-xl p-5 border border-indigo-200 shadow-md hover:shadow-lg transition-shadow">
                  <div className="flex items-center gap-3 mb-3">
                    <div className="p-2 bg-indigo-500 rounded-lg">
                      <BarChart3 className="h-4 w-4 text-white" />
                    </div>
                    <span className="font-bold text-indigo-800">Growth Velocity</span>
                  </div>
                  <p className="text-sm text-indigo-700 leading-relaxed">
                    ⚡ Period comparison shows {growthData.totalGrowth.percentGrowth > 0 ? 'positive' : 'mixed'} momentum.
                    <br /><br />
                    <span className="font-semibold">Next:</span> Set targets for next quarter based on current trends.
                  </p>
                </div>

                {/* Market opportunity insight */}
                <div className="bg-white rounded-xl p-5 border border-teal-200 shadow-md hover:shadow-lg transition-shadow">
                  <div className="flex items-center gap-3 mb-3">
                    <div className="p-2 bg-teal-500 rounded-lg">
                      <Activity className="h-4 w-4 text-white" />
                    </div>
                    <span className="font-bold text-teal-800">Market Opportunity</span>
                  </div>
                  <p className="text-sm text-teal-700 leading-relaxed">
                    🎯 Growth composition reveals expansion opportunities.
                    <br /><br />
                    <span className="font-semibold">Focus:</span> Scale activities showing consistent growth patterns.
                  </p>
                </div>
              </div>
            </div>
          </>
        )}
      </div>
    </div>
  )
}