LOCAL_DB_PASSWORD=

# Business Logic Configuration
TARGET_MEETUP_INCREASE=50
MIN_TARGET_MEETUPS=300

# JWT Secret (for authentication features)
JWT_SECRET=production-jwt-secret-misfits-ops-2024
